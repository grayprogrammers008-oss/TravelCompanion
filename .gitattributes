# Default behavior: auto-detect text files and let core.autocrlf handle endings
* text=auto

# Force CRLF for Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.rc text eol=crlf
*.sln text eol=crlf
*.vcxproj* text eol=crlf

# Force LF for Unix-specific files (or they break)
*.sh text eol=lf
*.bash text eol=lf
Makefile text eol=lf
*.mk text eol=lf
gradlew text eol=lf

# Explicit text formats
*.dart text
*.kt text
*.kts text
*.gradle text
*.java text
