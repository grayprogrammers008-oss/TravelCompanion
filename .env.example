# Travel Crew - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Claude AI (for Autopilot features)
CLAUDE_API_KEY=your-claude-api-key-here

# Mailgun Email Service (for trip invites)
MAILGUN_API_KEY=your-mailgun-api-key-here
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM_EMAIL=Travel Crew <noreply@mg.yourdomain.com>

# Unsplash Images (optional - for destination images)
UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here
