# Travel Crew - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Claude AI (for Autopilot features)
CLAUDE_API_KEY=your-claude-api-key-here

# Brevo (SendinBlue) Email Service (for trip invites, notifications)
BREVO_API_KEY=your-brevo-api-key-here
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=TravelCompanion

# Unsplash Images (optional - for destination images)
UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here

# Testing Configuration (Development Only)
# Shared password for all test users - DO NOT use in production
TEST_USER_PASSWORD=Test@1234
