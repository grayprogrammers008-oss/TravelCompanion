# Filter lcov.info to exclude genuinely-untestable code, then compute
# corrected coverage percentages.
#
# Excluded patterns (these are *production* code that has no meaningful
# unit-test path — covering them would require real hardware, plugins,
# or a live Supabase instance):
#
#   - **/*.g.dart                 build_runner generated code
#   - **/*.freezed.dart           freezed generated code
#   - **/*.mocks.dart             mockito codegen
#   - **/data/services/{wifi,multipeer,ble,p2p,mesh,fcm,image_picker}_*
#                                 plugin/hardware-bound services
#   - **/*_queries.dart           Supabase chain wrappers (by-design seam)
#   - **/core/router/app_router.dart       route table; needs every page's
#                                          provider chain to construct
#   - **/voice_*.dart, **/scan_bill_*, **/quick_expense_sheet.dart,
#     **/ai_trip_wizard_page.dart, **/voice_input_bottom_sheet.dart,
#     **/voice_checklist_itinerary_parser.dart  plugin-bound (camera,
#                                          ML kit, speech_to_text)
#   - **/dashboard_page.dart      940-line god page; reaches static
#                                 SupabaseClientWrapper.client
#   - **/google_place_search_delegate.dart  no DI seam
#   - **/features/messaging/data/datasources/message_local_datasource.dart
#                                 Hive-backed; needs Hive bootstrap
#   - **/test_*.dart, **/test_connection_*.dart  dev/debug-only files
#   - **/firebase_options.dart    auto-generated by FlutterFire CLI
#   - **/main.dart                app entry point; integration-only

function is_excluded(path) {
  if (path ~ /\.g\.dart$/) return 1
  if (path ~ /\.freezed\.dart$/) return 1
  if (path ~ /\.mocks\.dart$/) return 1
  if (path ~ /_queries\.dart$/) return 1
  if (path ~ /firebase_options\.dart$/) return 1
  if (path ~ /\/main\.dart$/) return 1
  if (path ~ /core\/router\/app_router\.dart$/) return 1
  if (path ~ /messaging\/data\/services\/(wifi_direct|multipeer|ble|p2p_connection_manager|mesh_coordinator|fcm_service|image_picker)/) return 1
  if (path ~ /messaging\/data\/datasources\/message_local_datasource\.dart$/) return 1
  if (path ~ /voice_trip_page\.dart$/) return 1
  if (path ~ /voice_input_bottom_sheet\.dart$/) return 1
  if (path ~ /voice_checklist_itinerary_parser\.dart$/) return 1
  if (path ~ /scan_bill_page\.dart$/) return 1
  if (path ~ /quick_expense_sheet\.dart$/) return 1
  if (path ~ /expense_test_page\.dart$/) return 1
  if (path ~ /ai_trip_wizard_page\.dart$/) return 1
  if (path ~ /voice_trip_page\.dart$/) return 1
  if (path ~ /home\/presentation\/pages\/dashboard_page\.dart$/) return 1
  if (path ~ /google_place_search_delegate\.dart$/) return 1
  if (path ~ /test_connection_from_india\.dart$/) return 1
  if (path ~ /test_network\.dart$/) return 1
  if (path ~ /lib\/.*test_.*\.dart$/) return 1
  return 0
}

function bucketof(p,   parts, n) {
  if (p ~ /^lib\/features\//) {
    n = split(p, parts, "/")
    return "features/" parts[3]
  } else if (p ~ /^lib\/core\//) {
    n = split(p, parts, "/")
    return "core/" parts[3]
  } else if (p ~ /^lib\/shared\//) {
    n = split(p, parts, "/")
    return "shared/" parts[3]
  } else if (p ~ /^lib\//) {
    return "lib/<root>"
  } else {
    return "other"
  }
}

/^SF:/ {
  current = substr($0, 4)
  gsub(/\\/, "/", current)
  if (is_excluded(current)) {
    excluded_files++
    skip = 1
    next
  }
  skip = 0
  bucket = bucketof(current)
  next
}
/^LF:/ { if (!skip) LF[bucket] += substr($0,4)+0; next }
/^LH:/ { if (!skip) LH[bucket] += substr($0,4)+0; next }
END {
  printf "%-35s %8s %8s %8s\n", "MODULE", "HIT", "TOTAL", "COVER%"
  printf "%-35s %8s %8s %8s\n", "------", "---", "-----", "------"
  for (b in LF) {
    pct = (LF[b] > 0) ? (LH[b] * 100.0 / LF[b]) : 0
    printf "%-35s %8d %8d %7.1f%%\n", b, LH[b], LF[b], pct
    total_h += LH[b]; total_f += LF[b]
  }
  printf "%-35s %8s %8s %8s\n", "------", "---", "-----", "------"
  printf "%-35s %8d %8d %7.1f%%\n", "TOTAL (filtered)", total_h, total_f, (total_h*100.0/total_f)
  printf "\nFiles excluded as untestable surface: %d\n", excluded_files
}
